# =============================================================================
# lm-cloud-sync environment variables
# =============================================================================
# Auth is auto-detected from available credentials:
#   - If LM_BEARER_TOKEN is set, uses Bearer auth
#   - If LM_ACCESS_ID + LM_ACCESS_KEY are set, uses LMv1 auth
#   - Set LM_AUTH_METHOD only to force a specific method (bearer or lmv1)
# =============================================================================

# LogicMonitor Configuration (required)
LM_COMPANY=your-company-name
LM_BEARER_TOKEN=lmb_your_bearer_token_here

# Alternative: LMv1 Authentication (use instead of bearer token)
# LM_ACCESS_ID=your_access_id
# LM_ACCESS_KEY=your_access_key

# Optional: Force auth method (auto-detected from credentials if not set)
# LM_AUTH_METHOD=bearer

# Optional: Parent group ID for cloud integrations (default: 1)
# LM_PARENT_GROUP_ID=1

# =============================================================================
# GCP Configuration
# =============================================================================

# Path to GCP service account key JSON file.
# The service account needs 'roles/viewer' or 'roles/resourcemanager.projectViewer'
# at the organization or folder level for auto-discovery.
GCP_SA_KEY_PATH=/path/to/gcp-service-account-key.json

# Alternative: Standard Google ADC env var (also read by config)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-service-account-key.json

# =============================================================================
# AWS Configuration
# =============================================================================

# AWS credentials for accessing Organizations API.
# The credentials need 'organizations:ListAccounts' permission on the management account.
# Note: AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY are read by boto3 directly,
# not by lm-cloud-sync config. Set them in the environment or ~/.aws/credentials.
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# Optional: IAM role name to assume in member accounts (default: LogicMonitorRole)
# AWS_ROLE_NAME=LogicMonitorRole

# Optional: Comma-separated list of AWS regions to monitor (default: us-east-1,us-west-2)
# AWS_REGIONS=us-east-1,us-west-2,eu-west-1

# =============================================================================
# Azure Configuration
# =============================================================================

# Azure Service Principal credentials.
# The service principal needs 'Reader' role at subscription or management group level.
# Create via: Azure Portal > App registrations > Certificates & secrets > New client secret
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your_client_secret_value

# Optional: Comma-separated list of Azure regions to monitor (default: eastus,westus2)
# AZURE_REGIONS=eastus,westus2,centralus
